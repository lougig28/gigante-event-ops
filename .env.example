# ─────────────────────────────────────────────────────────────────────────────
# Gigante Event Ops — environment
# Frontend (Vite) gets ONLY public values. All connector secrets live server-side
# in Supabase (Edge Function secrets / Vault) and NEVER reach the browser.
# ─────────────────────────────────────────────────────────────────────────────

# --- Frontend (committed as VITE_*, safe/public) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx        # publishable/anon key (RLS-protected)
VITE_APP_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Server-side ONLY — set via `supabase secrets set ...` or the dashboard.
# Listed here for reference; do NOT prefix these with VITE_ and do NOT ship to client.
# ─────────────────────────────────────────────────────────────────────────────

# Toast (reused from md-dashboard-deploy pattern; machine client)
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
# Restaurant GUIDs (known): Gigante=54df1082-cbd6-4fc2-9cc2-9b64d9d6c5a6  Mulinos=2fb746da-d104-4c3d-a017-fd9a23f5c31d
TOAST_GIGANTE_GUID=54df1082-cbd6-4fc2-9cc2-9b64d9d6c5a6
TOAST_MULINOS_GUID=2fb746da-d104-4c3d-a017-fd9a23f5c31d

# SevenRooms (direct REST 2_4 — reused from sr-daily.js pattern)
SEVENROOMS_CLIENT_ID=
SEVENROOMS_CLIENT_SECRET=
SEVENROOMS_VENUE_ID=

# Tripleseat (OAuth2 client_credentials — reused from ar-data.js pattern)
TRIPLESEAT_CLIENT_ID=
TRIPLESEAT_CLIENT_SECRET=
TRIPLESEAT_LOCATION_ID=

# Sling (Sling by Toast) — NO integration exists yet. Schedule source of truth.
# STUBBED. Fill when API access is provisioned. See SETUP.md §Sling.
SLING_API_TOKEN=
SLING_ORG_ID=

# Anthropic (optional — AI guest-brief / captain summary, reused from gigante-event-command)
ANTHROPIC_API_KEY=
